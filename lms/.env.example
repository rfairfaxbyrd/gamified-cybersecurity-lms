# What this file does
# - Documents the environment variables needed to run the LMS.
#
# How to change it
# - Copy this file to `.env` and fill in values.

# NextAuth/Auth.js secret (required). Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# Used by NextAuth for callback URLs in some environments.
# In dev you can usually omit this, but it's safer to set it.
NEXTAUTH_URL="http://localhost:3000"

# Prisma/SQLite connection string.
DATABASE_URL="file:./prisma/dev.db"

# Optional: Override where the app reads module assets from.
# Default (if unset): ../content (repo-root /content folder)
CONTENT_DIR="../content"

# Seed credentials (dev/demo only). Change before any real deployment.
SEED_ADMIN_EMAIL="admin@setonhill.edu"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_DEMO_EMAIL="demo@setonhill.edu"
SEED_DEMO_PASSWORD="Demo123!"
