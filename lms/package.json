{
  "name": "gamified-cybersecurity-lms",
  "private": true,
  "version": "0.1.0",
  "description": "Gamified Cybersecurity Awareness Training LMS (Next.js + Prisma + SQLite + NextAuth).",
  "scripts": {
    "predev": "npm run next:clear-cache && npm run prisma:generate && npm run next:ensure-manifests",
    "dev": "node scripts/run-next.mjs dev",
    "prebuild": "npm run prisma:generate",
    "build": "node scripts/run-next.mjs build",
    "prestart": "npm run prisma:generate",
    "start": "node scripts/run-next.mjs start",
    "lint": "node scripts/run-next.mjs lint",
    "postinstall": "node scripts/postinstall.mjs",
    "content:clear-cache": "node scripts/clear-content-cache.mjs",
    "next:clear-cache": "node scripts/clear-next-cache.mjs",
    "next:ensure-manifests": "node scripts/ensure-next-manifests.mjs",
    "prisma:ensure-client": "node scripts/ensure-prisma-client.mjs",
    "prisma:generate": "npm run prisma:ensure-client && node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio",
    "db:setup": "node ./node_modules/prisma/build/index.js db push && node ./node_modules/prisma/build/index.js db seed",
    "db:seed": "node ./node_modules/prisma/build/index.js db seed"
  },
  "prisma": {
    "seed": "node ./node_modules/tsx/dist/cli.cjs prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "extract-zip": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "h5p-standalone": "^3.8.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
